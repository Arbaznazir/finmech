generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  password          String
  name              String
  company           String?
  plan              String   @default("free") // free, standalone_all, standalone_standard, standard, investor (all_models)
  purchasedModels   String   @default("[]") // JSON array of standalone model slugs bought individually
  
  // Subscription fields
  subscriptionStatus String   @default("inactive") // active, inactive, cancelled, past_due
  subscriptionId     String?  // Razorpay subscription ID
  subscriptionPlan   String?  // standard, investor
  subscriptionStart  DateTime?
  subscriptionEnd    DateTime?
  razorpayCustomerId String?  // Razorpay customer ID
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  calculations  Calculation[]
  savedModels   SavedModel[]
  payments      Payment[]
}

model Calculation {
  id          String   @id @default(uuid())
  userId      String
  modelSlug   String   // e.g. "break-even", "income-statement"
  modelName   String
  tier        String   // free, standalone, standard, investor
  inputs      String   // JSON string of inputs
  outputs     String   // JSON string of outputs
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, modelSlug])
}

model SavedModel {
  id          String   @id @default(uuid())
  userId      String
  modelSlug   String
  modelName   String
  data        String   // JSON string of full model state
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, modelSlug])
}

model Payment {
  id                String   @id @default(uuid())
  userId            String
  razorpayOrderId   String   @unique
  razorpayPaymentId String?  // Filled after successful payment
  razorpaySignature String?  // For verification
  
  amount            Int      // Amount in paise (₹1 = 100 paise)
  currency          String   @default("INR")
  status            String   @default("created") // created, paid, failed, refunded
  
  plan              String   // standalone_model, standalone_all, standalone_standard, standard, investor
  billingCycle      String   // monthly, yearly, one_time
  modelSlug         String?  // for standalone_model purchases
  
  metadata          String?  // JSON string for additional data
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// Admin-configurable bundle / subscription pricing (amounts in paise)
model PlanPrice {
  id              String   @id @default(uuid())
  planKey         String   @unique // standalone_all, standalone_standard, standard, investor
  name            String
  description     String?
  priceMonthly    Int?     // null if not offered monthly
  priceYearly     Int?
  priceOneTime    Int?     // for one-time bundles
  discountPercent Int      @default(0)
  discountLabel   String?
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Per standalone model pricing (buy selected model only)
model ModelPrice {
  id              String   @id @default(uuid())
  modelSlug       String   @unique
  modelName       String
  priceOneTime    Int      // paise
  discountPercent Int      @default(0)
  discountLabel   String?
  isActive        Boolean  @default(true)
  updatedAt       DateTime @updatedAt
}

// Admin-editable (i) field guide copy per model field
model ModelFieldHint {
  id         String   @id @default(uuid())
  modelSlug  String
  fieldKey   String
  what       String
  why        String
  how        String?
  updatedAt  DateTime @updatedAt

  @@unique([modelSlug, fieldKey])
  @@index([modelSlug])
}

// Admin-managed FAQs — global, tier gallery, or per-model
model Faq {
  id          String   @id @default(uuid())
  scope       String   // global | tier | model
  tierSlug    String?  // free | standalone | standard | investor
  modelSlug   String?
  question    String
  answer      String
  sortOrder   Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([scope, tierSlug, modelSlug, sortOrder])
}

// Admin rules: conditional Smart Results bullets in model PDFs
model SmartResultPoint {
  id          String   @id @default(uuid())
  modelSlug   String
  message     String
  color       String   @default("#16a34a")
  conditions  String   // JSON: [{ field, op, value, value2? }]
  combineMode String   @default("all") // all = AND, any = OR
  sortOrder   Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([modelSlug, sortOrder])
}
